# Server-only keys (do NOT put real keys in git)
ODDS_API_KEY="your_the_odds_api_key"
ANTHROPIC_API_KEY="your_anthropic_key"

# Line movement in research grounding via The Odds API historical snapshots (paid plan).
# https://the-odds-api.com/historical-odds-data/ — one snapshot per research run (~10 credits/region/market).
# GAMBLYZER_HISTORICAL_LINE_MOVEMENT=0
# GAMBLYZER_HISTORICAL_LOOKBACK_HOURS=24
# GAMBLYZER_HISTORICAL_REGIONS=us

# Optional
GEMINI_API_KEY="your_gemini_key"
ODDS_API_REGIONS="us,us2,us_ex"

# EPL uses Bovada for main lines (NBA/MLB/NHL stay on DraftKings). EPL pool: moneyline + match totals only (no spreads).
# GAMBLYZER_EPL_SPORTSBOOK="bovada"
CLAUDE_MODEL="claude-sonnet-4-6"

# Estimated USD in the UI (server-side). Use plain numbers or currency strings ("3", "$3", "15.00").
# Values are USD per **1 million** tokens (see Anthropic pricing for your CLAUDE_MODEL). Web search is optional flat USD per tool call Anthropic bills (set 0 to omit).
# Example matches Sonnet 4.x list pricing as of early 2026 — confirm on https://docs.anthropic.com/en/docs/about-claude/pricing
# GAMBLYZER_ANTHROPIC_INPUT_USD_PER_MTOK=3
# GAMBLYZER_ANTHROPIC_OUTPUT_USD_PER_MTOK=15
# GAMBLYZER_WEB_SEARCH_COST_USD=0.01

# When set to 1, `/api/generate` (single pick + research) bundles counter in the same run as primary (same as UI “Include counter dossier”).
# GAMBLYZER_INCLUDE_COUNTER_ON_GENERATE=1

# AI research timeouts (ms). `/api/generate` full flow defaults to RESEARCH + 45s headroom.
# GAMBLYZER_RESEARCH_TIMEOUT_MS=240000
# GAMBLYZER_FULL_GENERATE_TIMEOUT_MS=300000

# Research output caps (see README “Research efficiency”). Defaults: 640 / 768 / 6500 chars.
# GAMBLYZER_RESEARCH_MAX_TOKENS=640
# GAMBLYZER_NARRATIVE_MAX_TOKENS=768
# GAMBLYZER_BIAS_NARRATIVE_MAX_TOKENS=900
# GAMBLYZER_RESEARCH_PASTE_CHARS=6500

# Claude-only multi-pick judge (`/api/judge`). Keep above client `JUDGE_FETCH_TIMEOUT_MS` in app/page.js.
# GAMBLYZER_JUDGE_TIMEOUT_MS=180000
# CLAUDE_JUDGE_MODEL=claude-sonnet-4-6

